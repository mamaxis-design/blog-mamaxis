---
import { getPosts } from '../lib/api';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = await getPosts();
const hero = posts[0];
const featured = posts.slice(1, 3);
const rest = posts.slice(3);
---

<BaseLayout
  title="mamaxis DESIGN — Blog"
  description="Jamstackを取り入れたWebサイト制作の記録と、旅の断片を綴るブログ。"
>

<!-- ── HERO（全ページ共通・固定） ── -->
<section class="w-full relative overflow-hidden" style="height:300px;">
  <img
    src="/hero.JPG"
    alt="mamaxis DESIGN hero"
    class="w-full h-full object-cover"
    style="object-position: center 40%;"
  />
  <div class="absolute inset-0" style="background: linear-gradient(to right, rgba(28,28,26,0.68) 0%, rgba(28,28,26,0.35) 60%, transparent 100%);"></div>
  <div class="absolute inset-0 flex flex-col justify-center">
    <div class="max-w-6xl mx-auto px-6 lg:px-10 w-full">
      <p class="font-noto font-medium tracking-[0.25em] text-accent uppercase mb-3" style="font-size: clamp(0.65rem, 1.2vw, 0.75rem);">mamaxis DESIGN</p>
      <h1 class="font-mincho text-white leading-snug tracking-wide mb-4" style="font-size: clamp(1.1rem, 3.5vw, 1.875rem);">
        旅と、コードと、<br>心地よいWebデザイン。
      </h1>
      <p class="font-noto font-normal tracking-wider text-white/85" style="font-size: clamp(0.75rem, 1.6vw, 0.875rem); line-height: 1.85;">
        旅で研ぎ澄まされた感性をデザインに、Jamstackを確かな安心に。<br>
        サイト制作の裏側から、私の心を動かす日常の一コマまで。
      </p>
    </div>
  </div>
</section>

<!-- ── FEATURED 2カラム ── -->
{featured.length > 0 && (
  <section class="max-w-6xl mx-auto px-6 lg:px-10 mt-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {featured.map((post: any) => (
        <a href={`/blog/${post.slug}`} class="card group block border border-[#D6D3CE] overflow-hidden hover:border-accent transition-colors duration-300" style="border-radius:2px;">
          <div class="overflow-hidden" style="height:240px;">
            {post.eyecatch
              ? <img src={post.eyecatch.url} alt={post.title} class="card-img w-full h-full object-cover" />
              : <div class="w-full h-full bg-[#ede9e2]"></div>
            }
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="font-noto font-normal text-xs tracking-[0.18em] text-accent uppercase">
                {post.category?.name ?? 'Blog'}
              </span>
              <span class="text-[#D6D3CE] text-xs">·</span>
              <span class="font-noto font-normal text-xs tracking-wider text-ink-muted">
                {new Date(post.publishedDate).toLocaleDateString('ja-JP')}
              </span>
            </div>
            <h3 class="font-mincho text-xl leading-relaxed tracking-wide text-ink group-hover:text-accent transition-colors duration-300 mb-2">
              {post.title}
            </h3>
            {post.excerpt && (
              <p class="font-noto font-normal text-sm leading-relaxed text-ink-muted line-clamp-2">
                {post.excerpt}
              </p>
            )}
            <p class="font-noto font-normal text-xs tracking-wider text-ink-muted mt-3">
              {post.readingTime}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- ── セクション区切り ── -->
{rest.length > 0 && (
  <div class="max-w-6xl mx-auto px-6 lg:px-10 mt-14 mb-6 flex items-center gap-4">
    <span class="sb-label" style="margin-bottom:0;">All Posts</span>
    <div class="flex-1 border-t border-[#D6D3CE]"></div>
  </div>
)}

<!-- ── REST 3カラム ── -->
{rest.length > 0 && (
  <section class="max-w-6xl mx-auto px-6 lg:px-10">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {rest.map((post: any) => (
        <a href={`/blog/${post.slug}`} class="card group block border border-[#D6D3CE] overflow-hidden hover:border-accent transition-colors duration-300" style="border-radius:2px;">
          <div class="overflow-hidden" style="height:180px;">
            {post.eyecatch
              ? <img src={post.eyecatch.url} alt={post.title} class="card-img w-full h-full object-cover" />
              : <div class="w-full h-full bg-[#ede9e2]"></div>
            }
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="font-noto font-normal text-xs tracking-[0.18em] text-accent uppercase">
                {post.category?.name ?? 'Blog'}
              </span>
              <span class="text-[#D6D3CE] text-xs">·</span>
              <span class="font-noto font-normal text-xs tracking-wider text-ink-muted">
                {new Date(post.publishedDate).toLocaleDateString('ja-JP')}
              </span>
            </div>
            <h3 class="font-mincho text-base leading-relaxed tracking-wide text-ink group-hover:text-accent transition-colors duration-300">
              {post.title}
            </h3>
            <p class="font-noto font-normal text-xs tracking-wider text-ink-muted mt-2">
              {post.readingTime}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- 記事が0件のとき -->
{posts.length === 0 && (
  <div class="max-w-6xl mx-auto px-6 lg:px-10 py-24 text-center">
    <p class="font-mincho text-xl text-ink-muted tracking-wide">まだ記事がありません</p>
  </div>
)}

</BaseLayout>