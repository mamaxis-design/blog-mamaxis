---
import { getPosts, getCategories } from '../../../lib/api';
import BaseLayout from '../../../layouts/BaseLayout.astro';
import Hero from '../../../components/Hero.astro';
export async function getStaticPaths() {
  const categories = await getCategories();
  return categories.map((cat: any) => ({
    params: { id: cat.id },
    props: { category: cat },
  }));
}
const { category } = Astro.props;
const allPosts = await getPosts();
const posts = allPosts.filter((p: any) => p.category?.id === category.id);
const featured = posts.slice(0, 2);
const rest = posts.slice(2, 6);
---

<BaseLayout title={`${category.name} — mamaxis DESIGN`} description={`${category.name}カテゴリの記事一覧`}>


<Hero />

<!-- カテゴリ見出し -->
<div class="max-w-6xl mx-auto px-6 lg:px-10 mt-10 mb-2 flex items-center gap-4">
  <a href="/blog/" class="font-noto font-normal text-xs tracking-widest text-ink-muted hover:text-accent transition-colors duration-200">← All Posts</a>
  <span class="text-[#D6D3CE] text-xs">·</span>
  <span class="font-noto font-normal text-xs tracking-[0.2em] text-accent uppercase">{category.name}</span>
  <div class="flex-1 border-t border-[#D6D3CE]"></div>
  <span class="font-cormorant text-sm text-ink-muted">{posts.length} posts</span>
</div>

<!-- FEATURED 2カラム -->
{featured.length > 0 && (
  <section class="max-w-6xl mx-auto px-6 lg:px-10 mt-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {featured.map((post: any) => (
        <a href={`/blog/${post.slug}`} class="card group block border border-[#D6D3CE] overflow-hidden hover:border-accent transition-colors duration-300" style="border-radius:2px;">
          <div class="overflow-hidden" style="height:240px;">
            {post.eyecatch
              ? <img src={`${post.eyecatch.url}?w=800&q=80`} alt={post.title} class="card-img w-full h-full object-cover" />
              : <div class="w-full h-full bg-[#ede9e2]"></div>
            }
          </div>
          <div class="p-6">
            <div class="flex items-center gap-2 mb-3">
              <span class="font-noto font-normal text-xs tracking-[0.18em] text-accent uppercase">
                {post.category?.name ?? 'Blog'}
              </span>
              <span class="text-[#D6D3CE] text-xs">·</span>
              <span class="font-noto font-normal text-xs tracking-wider text-ink-muted">
                {new Date(post.publishedDate).toLocaleDateString('ja-JP')}
              </span>
            </div>
            <h3 class="font-mincho text-xl leading-relaxed tracking-wide text-ink group-hover:text-accent transition-colors duration-300 mb-2">
              {post.title}
            </h3>
            {post.excerpt && (
              <p class="font-noto font-normal text-sm leading-relaxed text-ink-muted line-clamp-2">
                {post.excerpt}
              </p>
            )}
            <p class="font-noto font-normal text-xs tracking-wider text-ink-muted mt-3">
              {post.readingTime}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- REST 3カラム -->
{rest.length > 0 && (
  <section class="max-w-6xl mx-auto px-6 lg:px-10 mt-6">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
      {rest.map((post: any) => (
        <a href={`/blog/${post.slug}`} class="card group block border border-[#D6D3CE] overflow-hidden hover:border-accent transition-colors duration-300" style="border-radius:2px;">
          <div class="overflow-hidden" style="height:180px;">
            {post.eyecatch
              ? <img src={`${post.eyecatch.url}?w=600&q=80`} alt={post.title} class="card-img w-full h-full object-cover" />
              : <div class="w-full h-full bg-[#ede9e2]"></div>
            }
          </div>
          <div class="p-5">
            <div class="flex items-center gap-2 mb-2">
              <span class="font-noto font-normal text-xs tracking-[0.18em] text-accent uppercase">
                {post.category?.name ?? 'Blog'}
              </span>
              <span class="text-[#D6D3CE] text-xs">·</span>
              <span class="font-noto font-normal text-xs tracking-wider text-ink-muted">
                {new Date(post.publishedDate).toLocaleDateString('ja-JP')}
              </span>
            </div>
            <h3 class="font-mincho text-base leading-relaxed tracking-wide text-ink group-hover:text-accent transition-colors duration-300">
              {post.title}
            </h3>
            <p class="font-noto font-normal text-xs tracking-wider text-ink-muted mt-2">
              {post.readingTime}
            </p>
          </div>
        </a>
      ))}
    </div>
  </section>
)}

<!-- 記事が0件のとき -->
{posts.length === 0 && (
  <div class="max-w-6xl mx-auto px-6 lg:px-10 py-24 text-center">
    <p class="font-mincho text-xl text-ink-muted tracking-wide">{category.name} の記事はまだありません</p>
    <a href="/blog/" class="inline-block mt-6 font-noto font-normal text-xs tracking-widest text-accent hover:underline">← 全記事に戻る</a>
  </div>
)}

</BaseLayout>