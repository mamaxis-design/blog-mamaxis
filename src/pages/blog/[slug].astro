---
import { getPosts, getPostDetail } from '../../lib/api';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Hero from '../../components/Hero.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import ArticleSidebar from '../../components/ArticleSidebar.astro';
import RelatedPosts from '../../components/RelatedPosts.astro';
import ScrollReveal from '../../components/ScrollReveal.astro';
import { formatArticleContent } from '../../lib/article-content';
import { imageSizes, optimizeMicroCmsImageUrl } from '../../lib/images';

export async function getStaticPaths() {
  const posts = await getPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const { slug } = Astro.params;
const post = await getPostDetail(slug!);
const allPosts = await getPosts();

const relatedPosts = allPosts
  .filter((p) => p.id !== post.id)
  .slice(0, 5);

const optimizedContent = formatArticleContent(post.content);
const heroImageSrc = post.eyecatch
  ? optimizeMicroCmsImageUrl(post.eyecatch.url, imageSizes.hero)
  : undefined;
---

<BaseLayout
  title={`${post.metaTitle || post.title} — mamaxis DESIGN`}
  description={post.metaDescription || post.excerpt}
>
  <Hero imageSrc={heroImageSrc} imageAlt={post.title} />

  <div class="max-w-6xl mx-auto px-6 lg:px-10 py-12 flex flex-col lg:flex-row gap-12">
    <main class="w-full lg:w-[68%] flex flex-col min-h-screen">
      <header class="reveal-block article-header">
        <div class="mb-6 flex items-center gap-3 flex-wrap">
          <span class="font-noto text-[0.7rem] tracking-widest text-accent">
            {post.category?.name ?? 'BLOG'}
          </span>
          <span class="text-ink-muted text-xs">·</span>
          <span class="font-noto text-[0.7rem] text-ink-muted">
            {new Date(post.publishedDate).toLocaleDateString('ja-JP')}
          </span>
          <span class="text-ink-muted text-xs">·</span>
          <span class="font-noto text-[0.7rem] text-ink-muted">{post.readingTime}</span>
        </div>

        <h1 class="font-mincho text-2xl md:text-3xl leading-relaxed tracking-wide mb-4">{post.title}</h1>

        {post.tags && (
          <div class="flex gap-2 mb-8 flex-wrap">
            {post.tags.split(',').map((tag) => (
              <span class="tag-chip">{tag.trim()}</span>
            ))}
          </div>
        )}
      </header>

      <div class="article-body flex-1" set:html={optimizedContent} />

      <div class="reveal-block">
        <AuthorBio />
      </div>
    </main>

    <ArticleSidebar posts={relatedPosts} tags={post.tags} />
  </div>

  <RelatedPosts posts={relatedPosts} />
  <ScrollReveal />
</BaseLayout>
