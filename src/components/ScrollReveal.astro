<script>
  const prepareArticleBody = () => {
    const body = document.querySelector('.article-body');
    if (!body || body.dataset.revealPrepared === 'true') return;

    body.dataset.revealPrepared = 'true';
    body.querySelectorAll(':scope > *').forEach((el, index) => {
      el.classList.add('reveal-block');
      el.style.setProperty('--reveal-delay', `${Math.min(index * 70, 420)}ms`);
    });
  };

  const initScrollReveal = () => {
    prepareArticleBody();

    const elements = document.querySelectorAll(
      '.reveal-block:not(.is-visible), .reveal-card:not(.is-visible)',
    );
    if (!elements.length) return;

    const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    if (prefersReducedMotion) {
      elements.forEach((el) => el.classList.add('is-visible'));
      return;
    }

    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      },
      { threshold: 0.12, rootMargin: '0px 0px -32px 0px' },
    );

    elements.forEach((el) => observer.observe(el));
  };

  initScrollReveal();
  document.addEventListener('astro:page-load', initScrollReveal);
</script>
