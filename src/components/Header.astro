---
import { getCategories } from '../lib/api';
const categories = await getCategories();
---

<header class="bg-paper border-b-0 md:border-b md:border-rule sticky top-0 z-50 relative">
  <div class="max-w-6xl mx-auto px-6 lg:px-10">
    <div class="flex items-center justify-between py-4 md:py-5 border-b-0 md:border-b md:border-rule md:justify-center">
      <a href="/blog/">
        <img src="/logo.svg" alt="mamaxis DESIGN" width="80" height="112" class="opacity-90 object-contain hidden md:block" />
        <img src="/logo-text.svg" alt="mamaxis DESIGN" class="h-5 w-auto opacity-90 object-contain block md:hidden" />
      </a>

      <!-- ハンバーガーボタン（モバイルのみ） -->
      <button
        id="hamburger"
        class="md:hidden flex flex-col justify-center gap-[5px] w-6 h-6 flex-shrink-0"
        aria-label="メニューを開く"
        aria-expanded="false"
      >
        <span class="hamburger-line block w-full h-[1.5px] bg-ink transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-full h-[1.5px] bg-ink transition-all duration-300 origin-center"></span>
        <span class="hamburger-line block w-full h-[1.5px] bg-ink transition-all duration-300 origin-center"></span>
      </button>
    </div>

    <!-- PC用ナビ（md以上で表示） -->
    <nav class="hidden md:flex justify-center gap-8 md:gap-12 py-3.5">
      {categories.map((cat) => (
        <a
          href={`/blog/category/${cat.id}`}
          class="nav-item font-josefin font-600 text-sm tracking-[0.18em] text-ink-muted pb-1 uppercase"
        >
          {cat.name}
        </a>
      ))}
    </nav>

  </div>

  <!-- モバイル用ドロワーナビ（absolute配置でヒーローを押し下げない） -->
  <nav
    id="mobile-nav"
    class="md:hidden absolute top-full left-0 right-0 bg-paper overflow-hidden max-h-0 transition-all duration-300 ease-in-out border-t border-rule shadow-sm z-50"
  >
    <div class="max-w-6xl mx-auto px-6 lg:px-10">
      <div class="flex flex-col divide-y divide-rule">
        {categories.map((cat) => (
          <a
            href={`/blog/category/${cat.id}`}
            class="font-josefin font-semibold text-sm tracking-[0.18em] text-ink-muted py-3 hover:text-accent transition-colors duration-200 uppercase"
          >
            {cat.name}
          </a>
        ))}
        <div class="py-4 w-full px-4">
          <a
            href="https://mamaxis-design.com/contact"
            target="_blank"
            rel="noopener noreferrer"
            class="btn-outline-accent block w-full text-center py-2.5"
          >
            お問い合わせ
          </a>
        </div>
      </div>
    </div>
  </nav>
</header>

<script>
  const hamburger = document.getElementById('hamburger');
  const mobileNav = document.getElementById('mobile-nav');
  const lines = hamburger?.querySelectorAll('.hamburger-line');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.getAttribute('aria-expanded') === 'true';

    if (isOpen) {
      hamburger.setAttribute('aria-expanded', 'false');
      mobileNav!.style.maxHeight = '0';
      lines?.[0].removeAttribute('style');
      lines?.[1].removeAttribute('style');
      lines?.[2].removeAttribute('style');
    } else {
      hamburger.setAttribute('aria-expanded', 'true');
      mobileNav!.style.maxHeight = mobileNav!.scrollHeight + 'px';
      (lines?.[0] as HTMLElement).style.cssText = 'transform: translateY(6.5px) rotate(45deg)';
      (lines?.[1] as HTMLElement).style.cssText = 'opacity: 0';
      (lines?.[2] as HTMLElement).style.cssText = 'transform: translateY(-6.5px) rotate(-45deg)';
    }
  });
</script>