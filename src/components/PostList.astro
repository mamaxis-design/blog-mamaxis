---
import type { Post } from '../types/microcms';
import PostCard from './PostCard.astro';
import ScrollReveal from './ScrollReveal.astro';

interface Props {
  posts: Post[];
  emptyMessage?: string;
  reveal?: boolean;
}

const {
  posts,
  emptyMessage = 'まだ記事がありません',
  reveal = true,
} = Astro.props;

const listPosts = posts.slice(0, 8);
---

{listPosts.length > 0 ? (
  <section class="site-container mt-10 pb-4">
    <div class="post-grid">
      {listPosts.map((post, index) => (
        <PostCard post={post} index={index} reveal={reveal} />
      ))}
    </div>
  </section>
) : (
  <div class="site-container py-24 text-center">
    <p class="font-mincho text-xl text-ink-muted tracking-wide">{emptyMessage}</p>
  </div>
)}

{reveal && listPosts.length > 0 && <ScrollReveal />}
